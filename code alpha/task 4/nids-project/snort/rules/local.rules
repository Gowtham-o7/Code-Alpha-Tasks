# local.rules — Snort custom detection signatures
# Place in /etc/snort/rules/local.rules

# 1. Port scan detection
alert tcp any any -> $HOME_NET any (msg:"Possible TCP Port Scan"; flags:S; threshold:type both, track by_src, count 20, seconds 10; sid:1000001; rev:1;)

# 2. ICMP flood / ping sweep
alert icmp any any -> $HOME_NET any (msg:"Possible ICMP Flood/Ping Sweep"; itype:8; threshold:type both, track by_src, count 30, seconds 10; sid:1000002; rev:1;)

# 3. SSH brute force
alert tcp any any -> $HOME_NET 22 (msg:"Possible SSH Brute Force"; flags:S; threshold:type both, track by_src, count 10, seconds 30; sid:1000003; rev:1;)

# 4. SQL injection pattern
alert tcp any any -> $HOME_NET 80 (msg:"Possible SQL Injection Attempt"; content:"UNION SELECT"; nocase; sid:1000004; rev:1;)

# 5. Directory traversal
alert tcp any any -> $HOME_NET 80 (msg:"Possible Directory Traversal Attempt"; content:"../../"; sid:1000005; rev:1;)

# 6. Suspicious scanner User-Agent
alert tcp any any -> $HOME_NET 80 (msg:"Suspicious Scanner User-Agent"; content:"nikto"; nocase; sid:1000006; rev:1;)

# 7. Possible C2 / reverse shell port
alert tcp $HOME_NET any -> any 4444 (msg:"Possible C2/Reverse Shell Traffic on Port 4444"; flags:S; sid:1000007; rev:1;)

# 8. FTP anonymous login
alert tcp any any -> $HOME_NET 21 (msg:"FTP Anonymous Login Attempt"; content:"USER anonymous"; nocase; sid:1000008; rev:1;)
